{
  "_comment": "OpenClaw 配置示例 - 语义审计集成 (使用 llm-task)",
  "_description": "复制此文件到 ~/.openclaw/openclaw.json 并根据需要修改",
  
  "_note": "此配置使用 OpenClaw 官方的 llm-task 插件工具进行语义审计，直接使用 OpenClaw 配置的大模型，无需外部 API Key。",
  
  "plugins": {
    "entries": {
      "llm-task": {
        "enabled": true,
        "config": {
          "defaultProvider": "auto",
          "defaultModel": "auto",
          "timeoutMs": 60000,
          "maxTokens": 1500
        }
      }
    }
  },
  
  "agents": {
    "defaults": {
      "model": {
        "primary": "auto"
      }
    },
    "list": [
      {
        "id": "main",
        "tools": {
          "allow": ["llm-task"]
        }
      }
    ]
  },
  
  "skills": {
    "entries": {
      "ant-intl-skill-scanner": {
        "enabled": true,
        "config": {
          "semantic": {
            "enabled": true,
            "provider": "llm-task",
            "timeout_ms": 60000,
            "max_tokens": 1500,
            "thinking": "low"
          }
        }
      }
    },
    "load": {
      "watch": true,
      "watchDebounceMs": 250
    }
  }
}
