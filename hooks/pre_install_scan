#!/bin/bash
#
# Skill 安装前安全扫描钩子 (x-skill-scanner v7.0)
#
# 此脚本在 skill 安装前自动执行安全扫描
# 支持 OpenClaw、Claude Code、Cursor、Windsurf、QClaw 等平台
#

set -e

# 配置
SCANNER_DIR="${HOME}/.openclaw/skills/x-skill-scanner"
SCAN_SCRIPT="${SCANNER_DIR}/scripts/scan_skill.sh"
REPORTS_DIR="${SCANNER_DIR}/reports"

# 颜色
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# 打印函数
print_header() {
    echo ""
    echo -e "${BLUE}══════════════════════════════════════════════════════════════${NC}"
    echo -e "${BLUE}  🔒 Skill 安全扫描 (x-skill-scanner v7.0)${NC}"
    echo -e "${BLUE}══════════════════════════════════════════════════════════════${NC}"
    echo ""
}

print_result() {
    local level=$1
    local message=$2
    case $level in
        safe)
            echo -e "${GREEN}✅ $message${NC}"
            ;;
        warning)
            echo -e "${YELLOW}⚠️  $message${NC}"
            ;;
        danger)
            echo -e "${RED}🔴 $message${NC}"
            ;;
        *)
            echo -e "${BLUE}ℹ️  $message${NC}"
            ;;
    esac
}

# 检查依赖
check_dependencies() {
    if [[ ! -d "$SCANNER_DIR" ]]; then
        echo -e "${RED}Error: Scanner not found at $SCANNER_DIR${NC}"
        exit 1
    fi

    if [[ ! -f "$SCAN_SCRIPT" ]]; then
        echo -e "${RED}Error: Scan script not found at $SCAN_SCRIPT${NC}"
        exit 1
    fi

    if ! command -v python3 &> /dev/null; then
        echo -e "${RED}Error: Python3 is required but not installed${NC}"
        exit 1
    fi
}

# 执行扫描
run_scan() {
    local skill_path="$1"
    local scan_result=0

    echo "扫描目标: $skill_path"
    echo ""

    # 创建报告目录
    mkdir -p "$REPORTS_DIR"

    # 执行扫描
    if python3 "$SCANNER_DIR/lib/scanner.py" -t "$skill_path" --json -o "${REPORTS_DIR}/scan-$(date +%Y%m%d-%H%M%S).json" 2>&1; then
        scan_result=0
    else
        scan_result=$?
    fi

    return $scan_result
}

# 解析扫描结果
parse_result() {
    local json_file="$1"

    if [[ ! -f "$json_file" ]]; then
        echo -e "${RED}Error: Scan result file not found${NC}"
        return 1
    fi

    # 提取风险等级
    local risk_level=$(python3 -c "
import json
import sys
try:
    with open('$json_file', 'r') as f:
        data = json.load(f)
    print(data.get('risk_level', 'UNKNOWN'))
except:
    print('ERROR')
" 2>/dev/null || echo "ERROR")

    echo "$risk_level"
}

# 主函数
main() {
    local skill_path="$1"
    local skip_scan="${SKIP_SCAN:-0}"

    print_header

    # 检查是否跳过扫描
    if [[ "$skip_scan" == "1" ]]; then
        print_result warning "跳过安全扫描 (SKIP_SCAN=1)"
        exit 0
    fi

    # 检查依赖
    check_dependencies

    # 检查技能路径
    if [[ -z "$skill_path" ]]; then
        echo "Usage: $0 <skill-path>"
        echo ""
        echo "Options:"
        echo "  SKIP_SCAN=1   跳过安全扫描"
        exit 1
    fi

    if [[ ! -e "$skill_path" ]]; then
        print_result danger "技能路径不存在: $skill_path"
        exit 1
    fi

    # 执行扫描
    echo "开始安全扫描..."
    echo ""

    if run_scan "$skill_path"; then
        print_result safe "安全扫描通过"
        exit 0
    else
        local result=$?
        if [[ $result -eq 2 ]]; then
            print_result warning "安全扫描发现中危问题 - 建议人工审查"
            exit 2
        else
            print_result danger "安全扫描未通过 - 阻止安装"
            echo ""
            echo "如确定安全，可手动绕过:"
            echo "  SKIP_SCAN=1 <install-command>"
            exit 1
        fi
    fi
}

main "$@"